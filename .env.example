# Copy this file to .env and fill in real values.
# .env is git-ignored. Never commit secrets.

# --- App ---
# Host port Docker maps to the backend container's internal port 3000.
# Use a high-range port to avoid collisions with other NAS services.
APP_HOST_PORT=37801

# --- Postgres ---
# These are used by both the Postgres container and the app container.
# The database and username should stay generic (rename-proofing rule).
POSTGRES_DB=tracker
POSTGRES_USER=tracker
POSTGRES_PASSWORD=change_me_before_use

# Host port Docker exposes for the Postgres container.
# Allows the backend (and tests) to run locally against the same Postgres.
# Omit or set to 5432 if nothing else is using that port on the host.
POSTGRES_HOST_PORT=5432

# --- Constructed by docker-compose from the vars above ---
# When running the backend locally outside Docker, set this to use localhost.
DATABASE_URL=postgresql://tracker:change_me_before_use@localhost:5432/tracker

# --- Auth ---
# Initial user created on first startup when the database is empty (§13.1 bootstrap).
# Change the password after first login via Settings → Change Password.
# Also serves as break-glass recovery: if locked out, run:
#   docker compose exec app tsx src/scripts/reset-password.ts
# This resets the EXISTING user's password in-place. All data is preserved.
INITIAL_USER_EMAIL=admin@tracker.local
INITIAL_USER_PASSWORD=change_me_on_first_login

# --- Backup ---
# Directory on the host where pg_dump files land (picked up by restic or any backup tool).
# On the NAS: /mnt/user/appdata/life-tracker/backups
# In dev: ./backups (local directory, auto-created by the backup container)
BACKUP_DIR=./backups

# Cron schedule for automatic pg_dump (default: 3am daily UTC).
# Format: minute hour day-of-month month day-of-week
BACKUP_SCHEDULE=0 3 * * *

# How many days of dump files to retain before pruning (default: 14).
# The restic pipeline independently provides versioned off-site retention.
BACKUP_KEEP_DAYS=14

# --- v2 §9.4 Evidence base ---
# Identifier resolution against PubMed's E-utilities API for the evidence-verification
# gate. No API key is required for the app to work — NCBI allows unauthenticated
# requests at a lower rate limit (3/sec), which is more than this app needs at a
# review cadence of "at most weekly" (§9.2). Set NCBI_API_KEY to raise the limit if
# you register one: https://www.ncbi.nlm.nih.gov/account/settings/
# NCBI_EUTILS_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
# NCBI_API_KEY=
# NCBI_REQUEST_TIMEOUT_MS=10000

# --- v2 §9.2 The AI Review — provider-neutral LLM config ---
# Reviews are generated on-demand via POST /admin/generate-reviews (a real cron would
# call this on the day-start-bucketed daily tick). Nothing here is required at boot —
# a missing/misconfigured value only fails that specific call, never app startup.
#
# REVIEW_LLM_PROVIDER selects the adapter:
#   anthropic          — Claude via the Anthropic API (default if unset)
#   openai-compatible  — OpenAI, Google's Gemini OpenAI-compatible endpoint, or any local
#                        runtime that emulates the chat-completions format (Ollama,
#                        llama.cpp, LM Studio, vLLM). REVIEW_LLM_BASE_URL is what actually
#                        points it at one or the other — this is one adapter, not four.
#                        Tries tool/function calling first, falls back to JSON-mode
#                        response formatting for models that don't support reliable tool
#                        calling (common with small local models).
REVIEW_LLM_PROVIDER=anthropic
REVIEW_LLM_MODEL=claude-opus-4-8

# Used only when REVIEW_LLM_PROVIDER=anthropic:
# ANTHROPIC_API_KEY=

# Used only when REVIEW_LLM_PROVIDER=openai-compatible. REVIEW_LLM_BASE_URL is REQUIRED
# in that mode — the app still starts fine without it; only /admin/generate-reviews fails
# until it's set. REVIEW_LLM_MODEL above is reused for the model name in this mode too
# (e.g. "gpt-4o-mini", "gemini-2.0-flash", "llama3.1" — whatever your endpoint serves).
# Examples:
#   OpenAI:            REVIEW_LLM_BASE_URL=https://api.openai.com/v1
#   Gemini (compat):   REVIEW_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   Local (Ollama):    REVIEW_LLM_BASE_URL=http://localhost:11434/v1
# REVIEW_LLM_BASE_URL=
# REVIEW_LLM_API_KEY=

# --- Tests ---
# Integration tests connect here.  Defaults to DATABASE_URL if unset.
# WARNING: the integration test suite calls resetDatabase() which drops and
# recreates all tables.  Point this at a dedicated test database if you want
# to preserve development data across test runs.
#
# To create a dedicated test database (one-time setup):
#   docker compose exec db createdb -U tracker tracker_test
# Then uncomment:
# TEST_DATABASE_URL=postgresql://tracker:change_me_before_use@localhost:5432/tracker_test
